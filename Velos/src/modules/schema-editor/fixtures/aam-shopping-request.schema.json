{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://velos-registry/aam.shopping.AAMShoppingRequest:1.0.0",
  "title": "AAMShoppingRequest",
  "description": "Advanced Air Mobility shopping request. Canonical VELOS schema.",
  "domain": {
    "industry": "Aviation",
    "function": "AdvancedAirMobility",
    "subfunction": "Shopping"
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["CoreQuery"],
  "properties": {
    "CoreQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["OriginDestinations"],
      "properties": {
        "OriginDestinations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/OriginDestination" }
        },
        "Travelers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "Traveler": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/Traveler" }
            }
          }
        },
        "VehiclePreference": {
          "items": { "enum": ["EVTOL", "EHELICOPTER", "ESTOL"] }
        }
      }
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "Other": {
          "type": "object",
          "properties": {
            "OtherMetadata": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "RequestSource": { "type": "string", "maxLength": 64 },
                "ClientIP": { "type": "string", "format": "ipv4" }
              }
            }
          }
        }
      }
    }
  },
  "example": {
    "CoreQuery": {
      "OriginDestinations": [
        {
          "OriginLocation": { "Code": "JFK" },
          "DestinationLocation": { "Code": "EWR" },
          "DepartureDateTime": "2026-06-02T09:00:00Z"
        }
      ],
      "Travelers": {
        "Traveler": [{ "TravelerID": "T1", "PTC": "ADT" }]
      }
    },
    "Metadata": {
      "Other": {
        "OtherMetadata": {
          "RequestSource": "web",
          "BookingDestinationLocation": "EWR"
        }
      }
    }
  },
  "$defs": {
    "OriginDestination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["OriginLocation", "DestinationLocation"],
      "properties": {
        "OriginLocation": { "type": "object" },
        "DestinationLocation": { "type": "object" },
        "DepartureDateTime": { "type": "string", "format": "date-time" },
        "DepartureDate": { "type": "string", "format": "date" },
        "ViaPoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/GeoPoint" }
        }
      }
    },
    "GeoPoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "Longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "Traveler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["TravelerID"],
      "properties": {
        "TravelerID": { "type": "string", "pattern": "^[A-Z0-9]+$", "minLength": 1 },
        "PTC": { "type": "string", "enum": ["ADT", "CHD", "INF"] },
        "BaggageRequirements": { "$ref": "#/$defs/BaggageRequirements" }
      }
    },
    "BaggageRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Items": {
          "type": "array",
          "items": { "$ref": "#/$defs/BaggageItem" }
        }
      }
    },
    "BaggageItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Type": { "type": "string", "enum": ["CARRY_ON", "CHECKED"] },
        "WeightKg": { "type": "number", "minimum": 0, "maximum": 50 }
      }
    }
  }
}
